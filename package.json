{
  "name": "yvm-yt",
  "version": "0.1.0",
  "description": "Minimal Ink TUI for yt-dlp",
  "license": "MIT",
  "type": "module",
  "bin": {
    "yvm-yt": "./dist/bin/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun run bin/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "figlet": "^1.11.0",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "react-devtools-core": "^4.28.5",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.12",
    "typescript": "^5.8.3"
  }
}
